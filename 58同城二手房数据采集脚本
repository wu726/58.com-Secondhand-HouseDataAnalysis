# ===================== 工具函数 =====================
def init_csv():
    """初始化CSV文件"""
    headers = ["小区名称", "户型", "面积(㎡)", "朝向", "楼层", "建造年份", "总价(万)", "单价(元/㎡)", "核心卖点"]
